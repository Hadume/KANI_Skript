on load:
    if {att::RESULTS::*} does not contain "{@id}":
        add "{@id}" to {att::RESULTS::*}


function att_assets_fishing_luck(p: player):
    att_message_teller("<lang:kani.npc.fortune_telling.dialogue.result.4>")

    apply luck 0 to {_p} for 60 seconds



function att_assets_reset_fishing_luck(p: player):
    remove potion effect of luck from {_p}



options:
    id: fishing_luck # このidがfunctionで呼び出されるので、functionで使われているものと同じものをidとして登録してください
