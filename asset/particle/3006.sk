on load:
    if {hdm::registeredObjects::*} do not contain 3006:
        add 3006 to {hdm::registeredObjects::*}

every ticks:
    if {hdm::objects::*} contain 3006:
        # -525.5 91.5 194.5
        # particle enchant ~4 ~2.5 ~2 3 1 1.5 0.01 1 normal
        make 1 enchant at location(-521.5, 94, 196.5) with delta vector(3, 1, 1.5) with extra 0.01
